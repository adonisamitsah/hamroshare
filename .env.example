# @docs: =======================================================================
# @docs: HAMROSHARE ENVIRONMENT CONFIGURATION
# @docs: 
# @docs: This file is dynamically parsable by the Hamroshare UI Editor.
# @docs: Please adhere to the following formatting rules:
# @docs: 
# @docs: 1. Sections       -> ### [ SECTION NAME ] ###
# @docs: 2. Descriptions   -> # @info: Your description text here
# @docs: 3. Active Vars    -> KEY="value"
# @docs: 4. Disabled Vars  -> # KEY="value"
# @docs: =======================================================================

### [ CORE APPLICATION SETTINGS ] ###
ENVIRONMENT="development"
BASE_URL="http://localhost/hamroshare"

### [ DATABASE SETTINGS ] ###
DB_FILENAME="data.sqlite"

### [ TELEGRAM NOTIFICATION SERVICE ] ###
ENABLE_TELEGRAM_NOTIFICATION=false
TELEGRAM_BOT_TOKEN="1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789"
TELEGRAM_CHAT_IDS="111111111,222222222"
TELEGRAM_WEBHOOK_SECRET="your_secure_random_webhook_secret_here"

### [ TELEGRAM BACKUP ] ###
ENABLE_TELEGRAM_BACKUP=false
TELEGRAM_CHANNEL_ID="-1000000000000"

### [ WHATSAPP NOTIFICATION SERVICE ] ###
ENABLE_WHATSAPP_NOTIFICATION=false
WHATSAPP_GREENAPI_INSTANCE_ID="1234567890"
WHATSAPP_GREENAPI_TOKEN="your_greenapi_token_here"
WHATSAPP_TARGET_IDS="1234567890123-1234567890@g.us"
# WHATSAPP_TARGET_IDS="123456789012@c.us"

### [ TIMEZONE & ENVIRONMENT ] ###
# @info: Example for Nepal: Asia/Kathmandu. Example for UK: Europe/London
APP_TIMEZONE="Asia/Kathmandu"

### [ CRON & AUTOMATION ] ###
# @info: Client Exclusions For Portfolio Fetch
SKIP_CLIENTS_FOR_PORTFOLIO_VALUATION="John Doe, Jane Doe, Example Client"

# @info: Enable for IPO Sell Signals.
IPO_SIGNAL_ENABLE=false

### [ URL MASKING SECRETS ] ###
# @info: Used to encrypt and decrypt sequential database IDs into short URLs (e.g., s.php?id=84832).
# @info: This prevents malicious users from guessing sequential report links sent to Telegram and WhatsApp.

URL_MASK_PRIME=10007
# @info: PRIME must be a prime number. SALT can be any random 7-digit number.
URL_MASK_SALT=8483291